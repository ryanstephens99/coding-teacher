{
  "name": "codementor-ai",
  "version": "0.0.1",
  "description": "Intelligent coding convention teacher for Cursor IDE",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "dev": "lerna run dev --parallel",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "clean": "lerna clean && rimraf node_modules",
    "setup": "./scripts/setup.sh",
    "dev-start": "./scripts/dev-start.sh",
    "build-all": "./scripts/build-all.sh"
  },
  "devDependencies": {
    "lerna": "^8.0.0",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "author": "Ryan Stephens",
  "license": "MIT"
} 